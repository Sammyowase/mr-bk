{
  "name": "miratonrose",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon",
    "prisma:seed": "ts-node prisma/seed.ts",
    "build": "tsc",
    "build:all": "pm2 stop mr-backend && npm run build && pm2 restart mr-backend",
    "compile": "tsc -w",
    "migrate:prod": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:reset": "prisma migrate reset",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watchAll --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --watchAll --detectOpenHandles --forceExit",
    "test:e2e": "jest tests/e2e --detectOpenHandles --forceExit",
    "prepare": "husky install"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,html,css,scss}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "authors": [
    "Daniel Ojiezele",
    "Abdulbasit Abdullahi"
  ],
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.24.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "depcheck": "^1.4.7",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.1.9",
    "prettier": "^3.6.2",
    "supertest": "^7.1.3",
    "ts-jest": "^29.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.10.1",
