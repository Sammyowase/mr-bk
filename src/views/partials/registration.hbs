<div
  style="font-size: 16px; line-height: 1.6; color: #333;"
>
  <p>
    Thank you for registering on our platform,
    <strong>{{firstName}} {{lastName}}</strong>.
  </p>
  <p>
    Your OTP is:
    <span
      style="display: inline-block; font-size: 20px; font-weight: bold; background-color: #f0f0f0; padding: 6px 12px; border-radius: 4px;"
    >
      {{otp}}
    </span>
  </p>
  <p>Please use this OTP to verify your email address.</p>
  <p>This OTP will expire in {{expiresIn}} minutes.</p>

</div>